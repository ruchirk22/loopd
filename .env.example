# loopd needs NO configuration to start — this file only overrides defaults, and it's
# loaded automatically so you never have to `export` anything. `.env` is git-ignored.
#
#     cp .env.example .env    # optional; only if you want to change a default below
#
# A trailing ` # comment` after a value is stripped (quote the value for a literal '#').

# --- Auth: you don't set it here. ---
# loopd reuses your Claude Code login — if you can run `claude`, loopd works. Not signed in?
#     claude login
# For CI / headless only, loopd will honor an environment credential if you set one:
# ANTHROPIC_API_KEY=sk-ant-...          # billed as API usage
# CLAUDE_CODE_OAUTH_TOKEN=              # from `claude setup-token`

# --- Models: Opus 4.8 for BOTH agents, pinned by id (defaults shown) ---
# PM_MODEL=claude-opus-4-8
# DEV_MODEL=claude-opus-4-8

# --- Loop control ---
# BUDGET_USD=25                  # Opus on both agents: size for the real task
# MAX_ATTEMPTS_PER_STEP=3        # dev<->gates retries per review cycle
# MAX_REJECTIONS_PER_STEP=2      # PM rejections before it must replan/descope/abort
# MAX_REPLANS=3                  # plan mutations + failed finalizations
# MAX_TURNS_PER_CALL=40
# MAX_WALL_CLOCK_MIN=0           # 0 = no wall-clock cap
# TIMEOUT_COST_USD=1.0           # floor charged when a CLI call times out (rises to the
#                                # largest real per-call cost seen, so timeouts aren't undercharged)

# --- Tools ---
# DEV_ALLOWED_TOOLS=Read,Edit,Write,Bash,Glob,Grep
# PM_ALLOWED_TOOLS=Read,Glob,Grep

# --- PM context management / handover caps / timeouts ---
# CHECKPOINT_EVERY_REVIEWS=8
# HANDOVER_BYTES_CAP=150000
# HANDOVER_DIFF_CAP=20000
# GATE_LOG_TAIL=8000
# CALL_TIMEOUT_S=3600
# GATE_TIMEOUT_S=1800

# --- Execution Forecast (a cheap pre-run estimate of cost / runtime / steps) ---
# FORECAST_ENABLED=1                          # 0 disables the pre-run estimate entirely
# FORECAST_MODEL=claude-haiku-4-5-20251001    # deliberately CHEAP — the estimate must cost ~nothing
# FORECAST_TIMEOUT_S=300                       # timeout for the single estimate call
# FORECAST_MAX_TURNS=6                         # let it shallow-skim the repo, not read everything
# Estimator coefficients (deterministic; recalibrate for cheaper models — or let history do it).
# Every field of forecast.EstimatorConfig is overridable as FORECAST_<UPPER_NAME>, e.g.:
# FORECAST_COST_PER_PM_CALL_USD=0.30
# FORECAST_COST_PER_DEV_CALL_USD=0.60
# FORECAST_SECONDS_PER_DEV_CALL=110
# FORECAST_BASE_CONTINGENCY=0.15              # recommended-budget headroom over the estimate

# --- Architecture spine (binding per-project decisions, honored by every step) ---
# ARCHITECTURE_ENABLED=1                       # 0 skips the pre-plan architecture step
# ARCHITECT_MODEL=claude-opus-4-8             # load-bearing decisions → the capable model
# ARCHITECT_MAX_TURNS=8                        # let the Architect skim the repo, not read everything

# --- Program orchestration (`loopd build` — a PRD becomes ordered, governed epics) ---
# PROGRAM_MODEL=claude-opus-4-8               # decomposes the PRD into epics
# PROGRAM_MAX_TURNS=8

# --- GitHub (optional; via the `gh` CLI — loopd never handles tokens) ---
# GITHUB_ENABLED=1              # 0 disables GitHub features even when gh is authenticated
# GITHUB_AUTO_PR=0             # 1 opens the PR after a successful run without asking
# GITHUB_PR_BASE=              # base branch for PRs (blank = the repo's default branch)
# GITHUB_PR_DRAFT=0            # 1 opens PRs as drafts

# --- Safety / git ---
# DEV_PERMISSION_MODE=bypassPermissions   # only safe inside the sandbox
# USE_RUN_BRANCH=1                        # isolate each run on agentic/run-<ts>
